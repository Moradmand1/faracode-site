<!-- جمله شعاری -->
<div style="text-align: center; margin: 10px 0 -50px 0;">
    <div style="max-width: 650px; margin: 0 auto; background: #f0f7ff; border-radius: 40px; padding: 15px 25px; border-right: 4px solid #0066cc;">
        <p style="font-size: 17px; font-weight: 500; color: #1a1a2e; margin: 0;">✨ شماره یک بودن، انتخاب ما نیست؛ خواست مشتریان ماست ✨</p>
    </div>
</div>

<script>
    function drawCircle(canvasId, percentage) {
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const centerX = canvas.width / 2;
        const centerY = canvas.height / 2;
        const radius = 78;
        const startAngle = -Math.PI / 2;
        const endAngle = startAngle + (percentage / 100) * (Math.PI * 2);
        
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.beginPath();
        ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
        ctx.strokeStyle = '#e0e0e0';
        ctx.lineWidth = 10;
        ctx.stroke();
        
        ctx.beginPath();
        ctx.arc(centerX, centerY, radius, startAngle, endAngle);
        const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
        gradient.addColorStop(0, '#0066cc');
        gradient.addColorStop(1, '#00a3cc');
        ctx.strokeStyle = gradient;
        ctx.lineWidth = 10;
        ctx.lineCap = 'round';
        ctx.stroke();
    }
    
    function animateNumber(element, start, end, duration, canvasId, maxValue) {
        if (start === end) return;
        let startTime = null;
        function updateNumber(currentTime) {
            if (!startTime) startTime = currentTime;
            const progress = Math.min((currentTime - startTime) / duration, 1);
            const currentValue = Math.floor(progress * (end - start) + start);
            element.innerText = currentValue;
            const percentage = (currentValue / maxValue) * 100;
            drawCircle(canvasId, Math.min(percentage, 100));
            if (progress < 1) requestAnimationFrame(updateNumber);
        }
        requestAnimationFrame(updateNumber);
    }
    
    function isElementInViewport(el) {
        const rect = el.getBoundingClientRect();
        const windowHeight = window.innerHeight || document.documentElement.clientHeight;
        return rect.top <= windowHeight - 100;
    }
    
    let animated = false;
    function initStats() {
        if (animated) return;
        const statSection = document.getElementById('stats-section');
        if (!statSection) return;
        if (isElementInViewport(statSection)) {
            animated = true;
            const counters = document.querySelectorAll('.stat-number');
            const targets = [67, 170, 41];
            const canvasIds = ['circle1', 'circle2', 'circle3'];
            counters.forEach((counter, index) => {
                const target = targets[index];
                if (!isNaN(target)) {
                    drawCircle(canvasIds[index], 0);
                    animateNumber(counter, 0, target, 2000, canvasIds[index], target);
                }
            });
            window.removeEventListener('scroll', initStats);
            window.removeEventListener('resize', initStats);
        }
    }
    
    window.addEventListener('scroll', initStats);
    window.addEventListener('resize', initStats);
    setTimeout(initStats, 500);
</script>

<script>
    // انیمیشن اسکرول برای بخش‌ها
    function isElementInViewport(el) {
        const rect = el.getBoundingClientRect();
        const windowHeight = window.innerHeight || document.documentElement.clientHeight;
        return rect.top <= windowHeight - 100;
    }

    function checkScrollAnimation() {
        const animatedElements = document.querySelectorAll('.animate-on-scroll');
        animatedElements.forEach(el => {
            if (isElementInViewport(el) && !el.classList.contains('animated')) {
                el.classList.add('animated');
            }
        });
    }

    window.addEventListener('scroll', checkScrollAnimation);
    window.addEventListener('resize', checkScrollAnimation);
    setTimeout(checkScrollAnimation, 500);
</script>

