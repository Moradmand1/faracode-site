<%- include('partials/header') %>

<h1>تماس با ما</h1>

<div style="display: flex; gap: 40px; flex-wrap: wrap;">
    <div style="flex: 1;" class="card">
        <h2>اطلاعات تماس</h2>
        <p><strong>آدرس:</strong> تهران، خیابان اصلی، پلاک 123</p>
        <p><strong>تلفن:</strong> 12345678-021</p>
        <p><strong>ایمیل:</strong> info@faracode1.ir</p>
        <p><strong>ساعات کاری:</strong> شنبه تا چهارشنبه 9 الی 17</p>
    </div>
    
    <div style="flex: 1;" class="card">
        <h2>فرم تماس</h2>
        <form action="/contact" method="POST">
            <div class="form-group">
                <label>نام و نام خانوادگی *</label>
                <input type="text" name="name" required>
            </div>
            <div class="form-group">
                <label>ایمیل *</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label>تلفن تماس</label>
                <input type="text" name="phone">
            </div>
            <div class="form-group">
                <label>پیام شما *</label>
                <textarea name="message" required></textarea>
            </div>
            <button type="submit" class="btn">ارسال پیام</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>