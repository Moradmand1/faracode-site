<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'فراکد | طراحی سایت و اپلیکیشن' %></title>
    <style>
        @import url('https://cdn.jsdelivr.net/gh/rastikerdar/shabnam-font@v5.0.0/dist/font-face.css');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Shabnam', 'Tahoma', 'Arial', sans-serif;
            background: linear-gradient(135deg, #f0f2f5 0%, #e0e4e8 100%);
            color: #1a1a2e;
            line-height: 1.6;
            position: relative;
        }
        
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 20% 80%, rgba(0,102,204,0.03) 0%, transparent 50%),
                repeating-linear-gradient(45deg, rgba(0,102,204,0.02) 0px, rgba(0,102,204,0.02) 2px, transparent 2px, transparent 8px);
            pointer-events: none;
            z-index: 0;
        }
        
        .container, .main-content, header, footer {
            position: relative;
            z-index: 1;
        }
        
        .container {
            max-width: 1200px;
            margin: auto;
            padding: 0 20px;
        }
        
        /* انیمیشن اسکرول */
        .animate-on-scroll {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1), transform 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }
        
        .animate-on-scroll.animated {
            opacity: 1 !important;
            transform: translateY(0) !important;
        }
        
        /* هدر */
        header {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(12px);
            box-shadow: 0 4px 30px rgba(0,0,0,0.05);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(0,102,204,0.1);
        }
        
        header.scrolled {
            padding: 5px 0;
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }
        
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            transition: all 0.3s ease;
        }
        
        header.scrolled .header-content {
            padding: 8px 0;
        }
        
        /* لوگو */
        .logo-link {
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 2px;
            font-size: 28px;
            font-weight: 800;
            background: linear-gradient(135deg, #0066cc, #00a3cc, #0066cc);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: shine 3s linear infinite;
        }
        
        .logo-img {
            height: 35px;
            width: auto;
            background: none;
        }
        
        .logo span {
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
            color: #1a1a2e;
            font-weight: 600;
        }
        
        @keyframes shine {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }
        
        /* منو */
        nav {
            display: flex;
            gap: 8px;
        }
        
        nav a {
            color: #1a1a2e;
            text-decoration: none;
            padding: 8px 18px;
            margin: 0;
            transition: all 0.3s ease;
            font-weight: 500;
            border-radius: 30px;
            position: relative;
        }
        
        nav a::before {
            content: '';
            position: absolute;
            bottom: 0;
            right: 50%;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, #0066cc, #00a3cc);
            transition: all 0.3s ease;
            border-radius: 3px;
            transform: translateX(50%);
        }
        
        nav a:hover::before {
            width: 70%;
        }
        
        nav a:hover {
            color: #0066cc;
            background: rgba(0,102,204,0.05);
        }
        
        nav a:last-child {
            background: linear-gradient(135deg, #0066cc, #00a3cc);
            color: white;
            box-shadow: 0 4px 12px rgba(0,102,204,0.3);
        }
        
        nav a:last-child::before {
            display: none;
        }
        
        nav a:last-child:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,102,204,0.4);
            background: linear-gradient(135deg, #0055aa, #0099bb);
        }
        
        /* منوی همبرگری */
        .menu-toggle {
            display: none;
            flex-direction: column;
            cursor: pointer;
        }
        
        .menu-toggle span {
            width: 25px;
            height: 3px;
            background: #0066cc;
            margin: 3px 0;
            border-radius: 3px;
            transition: 0.3s;
        }
        
        /* ریسپانسیو */
        @media (max-width: 768px) {
            .menu-toggle {
                display: flex;
            }
            
            nav {
                position: fixed;
                top: 70px;
                right: -100%;
                width: 250px;
                height: calc(100vh - 70px);
                background: rgba(255, 255, 255, 0.98);
                backdrop-filter: blur(12px);
                flex-direction: column;
                padding: 20px;
                gap: 15px;
                transition: right 0.3s ease;
                box-shadow: -5px 0 30px rgba(0,0,0,0.1);
            }
            
            nav.active {
                right: 0;
            }
            
            nav a {
                display: block;
                text-align: center;
                padding: 12px;
            }
            
            nav a::before {
                display: none;
            }
        }
        
        .main-content {
            margin-top: 90px;
            min-height: 500px;
        }
        
        /* دکمه‌ها */
        .btn {
            display: inline-block;
            background: linear-gradient(135deg, #0066cc, #00a3cc);
            color: #ffffff;
            padding: 12px 32px;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            text-decoration: none;
            font-weight: bold;
            font-family: 'Shabnam', 'Tahoma', sans-serif;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(0,102,204,0.3);
        }
        
        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,102,204,0.4);
        }
        
        .btn-outline {
            background: transparent;
            border: 2px solid #0066cc;
            color: #0066cc;
            box-shadow: none;
        }
        
        .btn-outline:hover {
            background: linear-gradient(135deg, #0066cc, #00a3cc);
            color: #ffffff;
            border: 2px solid transparent;
        }
        
        /* فرم‌ها */
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #1a1a2e;
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 12px;
            font-size: 16px;
            font-family: 'Shabnam', 'Tahoma', sans-serif;
            transition: all 0.3s;
        }
        
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #0066cc;
            box-shadow: 0 0 0 3px rgba(0,102,204,0.1);
        }
        
        /* کارت‌ها */
        .card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 24px;
            padding: 30px;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        }
        
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 32px rgba(0,0,0,0.1);
            background: rgba(255, 255, 255, 0.98);
        }
        
        /* گریدها */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }
        
        /* تایتل‌ها */
        h1 {
            font-size: 42px;
            margin-bottom: 20px;
            color: #000000;
        }
        
        h2 {
            font-size: 32px;
            margin-bottom: 20px;
            text-align: center;
            color: #1a1a2e;
        }
        
        h3 {
            font-size: 22px;
            margin-bottom: 15px;
            color: #0066cc;
        }
        
        .section {
            padding: 60px 0;
        }
        
        .bg-light {
            background: rgba(255,255,255,0.5);
            border-radius: 40px;
            margin: 20px 0;
        }
        
        /* جدول */
        table {
            width: 100%;
            background: #fff;
            border-collapse: collapse;
            border-radius: 16px;
            overflow: hidden;
        }
        
        table th,
        table td {
            padding: 12px;
            text-align: right;
            border-bottom: 1px solid #eee;
        }
        
        table th {
            background: linear-gradient(135deg, #0066cc, #00a3cc);
            color: white;
        }
        
        table tr:hover {
            background: #f8f9fa;
        }
        
        /* بخش آمار */
        .stat-number {
            font-size: 48px;
            font-weight: bold;
            background: linear-gradient(135deg, #0066cc, #ffffff)
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .stat-item {
            text-align: center;
            position: relative;
        }
        
        .circle-container {
            position: relative;
            width: 180px;
            height: 180px;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .circle-container .stat-number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 64x;
    font-weight: bold;
    background: linear-gradient(135deg, #00a3cc, #ffffff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0;
}
        
        .progress-circle {
            position: absolute;
            top: 0;
            left: 0;
        }
        
        /* بخش آمار پس‌زمینه */
        #stats-section {
            background: linear-gradient(135deg, #0b2b3f, #1a4a6f, #0d2b45);
            border-radius: 50px;
            margin: 60px 0;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }
        
        .stats-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1e5a8a, #2c6e9e, #1e5a8a);
            opacity: 0.25;
            animation: gradientShift 6s ease infinite;
            z-index: 1;
        }
        
        @keyframes gradientShift {
            0% { opacity: 0.2; }
            50% { opacity: 0.35; }
            100% { opacity: 0.2; }
        }
        
        .stats-dots {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 40%, rgba(100,200,255,0.08) 1px, transparent 1px);
            background-size: 30px 30px;
            z-index: 2;
            animation: dotsMove 20s linear infinite;
        }
        
        @keyframes dotsMove {
            0% { background-position: 0 0; }
            100% { background-position: 60px 60px; }
        }
        
        .stats-wave {
            position: absolute;
            left: 0;
            width: 100%;
            height: 80px;
            background-size: cover;
            z-index: 3;
            pointer-events: none;
        }
        
        .wave-top {
            top: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="white" opacity="0.15"/></svg>') repeat-x;
            background-size: 1200px 80px;
        }
        
        .wave-bottom {
            bottom: 0;
            transform: rotate(180deg);
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="white" opacity="0.1"/></svg>') repeat-x;
            background-size: 1200px 80px;
        }
        
        #stats-section p {
            color: rgba(255,255,255,0.85) !important;
            text-shadow: 0 1px 3px rgba(0,0,0,0.15);
        }
        
        #stats-section .circle-container canvas {
            filter: drop-shadow(0 4px 10px rgba(0,0,0,0.15));
        }
        
        /* فوتر */
        footer {
            background: linear-gradient(135deg, #0a0f1c 0%, #0f172a 30%, #1a1a3e 70%, #0f172a 100%);
            text-align: right;
            padding: 0;
            margin-top: 60px;
            color: #cccccc;
            border-top: 1px solid rgba(255,255,255,0.05);
            position: relative;
            overflow: hidden;
        }
        
        footer::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(0,102,204,0.08), transparent 50%);
            pointer-events: none;
            animation: footerGlow 8s ease-in-out infinite;
        }
        
        @keyframes footerGlow {
            0% { opacity: 0.3; transform: translate(0, 0); }
            50% { opacity: 0.6; transform: translate(5%, 2%); }
            100% { opacity: 0.3; transform: translate(0, 0); }
        }
        
        footer::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #0066cc, #00a3cc, #0066cc, transparent);
            animation: shimmer 3s infinite;
        }
        
        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        footer h3::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 50px;
            height: 3px;
            background: linear-gradient(90deg, #0066cc, #00a3cc, #0066cc);
            border-radius: 3px;
        }
		/* ==================== ریسپانسیو کامل ==================== */

/* تبلت (عرض کمتر از 992px) */
@media (max-width: 992px) {
    .container {
        padding: 0 15px;
    }
    
    h1 {
        font-size: 36px;
    }
    
    h2 {
        font-size: 28px;
    }
    
    .grid-3 {
        gap: 20px;
    }
    
    .hero-section {
        flex-direction: column-reverse !important;
        text-align: center;
    }
    
    .hero-text, .hero-image {
        flex: none;
        width: 100%;
    }
    
    .hero-text h1 {
        text-align: center !important;
    }
    
    .hero-text p {
        text-align: center !important;
    }
    
    .hero-text div {
        text-align: center !important;
    }
}

/* موبایل (عرض کمتر از 768px) */
@media (max-width: 768px) {
    body {
        font-size: 14px;
    }
    
    .container {
        padding: 0 12px;
    }
    
    .main-content {
        margin-top: 70px;
    }
    
    h1 {
        font-size: 28px;
    }
    
    h2 {
        font-size: 24px;
    }
    
    h3 {
        font-size: 20px;
    }
    
    .btn {
        padding: 10px 20px;
        font-size: 14px;
    }
    
    .section {
        padding: 40px 0;
    }
    
    .grid-3 {
        grid-template-columns: 1fr;
        gap: 20px;
        margin-top: 30px;
    }
    
    .card {
        padding: 20px;
    }
    
    /* دایره‌های آمار */
    .circle-container {
        width: 140px !important;
        height: 140px !important;
    }
    
    .circle-container .stat-number {
        font-size: 36px !important;
    }
    
    #stats-section {
        padding: 40px 0 !important;
        margin: 20px 0 !important;
        border-radius: 30px;
    }
    
    .grid-3[style*="gap: 50px"] {
        gap: 30px !important;
    }
    
    /* کارت معرفی */
    .intro-card {
        padding: 25px 20px !important;
    }
    
    .intro-card img {
        height: 30px !important;
    }
    
    .intro-card h3 {
        font-size: 20px !important;
    }
    
    .intro-card p {
        font-size: 15px !important;
    }
    
    /* جمله شعاری */
    .intro-card + div {
        margin: 10px 0 0 0 !important;
    }
    
    .intro-card + div div {
        padding: 12px 15px !important;
    }
    
    .intro-card + div div p {
        font-size: 14px !important;
    }
    
    /* فوتر */
    .footer-content {
        flex-direction: column;
        gap: 25px !important;
        text-align: center;
    }
    
    .footer-content > div {
        text-align: center !important;
    }
    
    footer h3::after {
        right: 50%;
        transform: translateX(50%);
    }
    
    footer a:hover {
        padding-right: 0 !important;
    }
    
    /* جدول پیام‌ها (پنل ادمین) */
    table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
    }
}

/* موبایل خیلی کوچک (عرض کمتر از 480px) */
@media (max-width: 480px) {
    h1 {
        font-size: 24px;
    }
    
    h2 {
        font-size: 20px;
    }
    
    .logo {
        font-size: 22px;
    }
    
    .logo-img {
        height: 28px !important;
    }
    
    .btn {
        padding: 8px 16px;
        font-size: 13px;
    }
    
    .circle-container {
        width: 120px !important;
        height: 120px !important;
    }
    
    .circle-container .stat-number {
        font-size: 28px !important;
    }
    
    .stat-item p {
        font-size: 14px !important;
    }
}
    </style>
</head>
<body>
    <header id="main-header">
        <div class="container">
            <div class="header-content">
                <a href="/" class="logo-link">
                    <div class="logo">
                        <img src="/images/Logos/1.png" alt="فراکد" class="logo-img">
                        فرا<span>کد</span>
                    </div>
                </a>
                <div class="menu-toggle" id="menu-toggle">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
                <nav id="main-nav">
                    <a href="/">خانه</a>
                    <a href="/about">درباره ما</a>
                    <a href="/services">خدمات</a>
                    <a href="/portfolio">نمونه کارها</a>
                    <a href="/contact">تماس با ما</a>
                    <a href="/admin/login">ورود</a>
                </nav>
            </div>
        </div>
    </header>
    
    <script>
        // افکت اسکرول برای کوچک شدن هدر
        window.addEventListener('scroll', function() {
            const header = document.getElementById('main-header');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });
        
        // منوی همبرگری برای موبایل
        const menuToggle = document.getElementById('menu-toggle');
        const mainNav = document.getElementById('main-nav');
        
        if (menuToggle) {
            menuToggle.addEventListener('click', function() {
                mainNav.classList.toggle('active');
                const spans = menuToggle.querySelectorAll('span');
                if (mainNav.classList.contains('active')) {
                    spans[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
                    spans[1].style.opacity = '0';
                    spans[2].style.transform = 'rotate(-45deg) translate(7px, -6px)';
                } else {
                    spans[0].style.transform = 'none';
                    spans[1].style.opacity = '1';
                    spans[2].style.transform = 'none';
                }
            });
        }
        
        // بستن منو با کلیک روی لینک‌ها
        document.querySelectorAll('#main-nav a').forEach(link => {
            link.addEventListener('click', () => {
                mainNav.classList.remove('active');
                if (menuToggle) {
                    const spans = menuToggle.querySelectorAll('span');
                    spans[0].style.transform = 'none';
                    spans[1].style.opacity = '1';
                    spans[2].style.transform = 'none';
                }
            });
        });
    </script>
    
    <div class="main-content">
        <div class="container">